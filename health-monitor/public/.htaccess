Options -Indexes

# Redirect all requests to index.html for SPA
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Skip files and directories that actually exist
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Redirect everything else to index.html
    RewriteRule ^ index.html [L]
</IfModule>

# Enable gzip compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json application/xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# Cache static assets for 1 year
<IfModule mod_expires.c>
    ExpiresActive On

    # HTML — no cache (always fresh)
    ExpiresByType text/html                  "access plus 0 seconds"

    # JS and CSS — versioned by Vite hash, cache forever
    ExpiresByType application/javascript     "access plus 1 year"
    ExpiresByType text/css                   "access plus 1 year"

    # Images and fonts
    ExpiresByType image/svg+xml              "access plus 1 year"
    ExpiresByType image/png                  "access plus 1 year"
    ExpiresByType image/jpeg                 "access plus 1 year"
    ExpiresByType image/webp                 "access plus 1 year"
    ExpiresByType font/woff2                 "access plus 1 year"
    ExpiresByType font/woff                  "access plus 1 year"
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Cache-Control for versioned assets
    <FilesMatch "\.(js|css|svg|png|jpg|jpeg|webp|woff|woff2)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # No cache for HTML
    <FilesMatch "\.html$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>
</IfModule>
